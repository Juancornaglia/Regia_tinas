{
  "version": 2,
  "builds": [
    {
      "src": "home/backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "home/front-end/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "home/backend/app.py" 
    },
    { 
      "source": "/(.*)", 
      "destination": "home/front-end/$1" 
    }
  ]
}